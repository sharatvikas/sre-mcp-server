# SRE MCP Server — Environment Configuration
# Copy to .env and fill in your values

# ── PagerDuty ─────────────────────────────────────────────────
PAGERDUTY_TOKEN=your-pagerduty-api-token

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_URL=https://grafana.your-org.com
GRAFANA_TOKEN=your-grafana-service-account-token
GRAFANA_DATASOURCE_UID=prometheus   # UID of your Prometheus datasource

# ── Kubernetes ────────────────────────────────────────────────
KUBECONFIG=/home/user/.kube/config  # Omit to use in-cluster config

# ── AWS ───────────────────────────────────────────────────────
AWS_PROFILE=your-aws-profile        # Or use AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# ── Runbooks ──────────────────────────────────────────────────
RUNBOOK_DIR=/path/to/your/runbooks  # Directory of Markdown runbook files
